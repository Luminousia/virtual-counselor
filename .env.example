# =============================================================
# 本地开发：复制此文件为 .env.local，填写后不会提交到 Git
# 生产部署：在 Vercel 控制台 Settings → Environment Variables 填写
# =============================================================

# ── 服务端（Vercel Serverless / Edge Functions 使用，不暴露给浏览器）──
# DeepSeek AI Key（https://platform.deepseek.com/api_keys）
DEEPSEEK_API_KEY=

# MiniMax TTS Key（https://platform.minimaxi.com/user-center/basic-information/interface-key）
MINIMAX_TTS_API_KEY=

# ── 本地开发备用（VITE_ 前缀会嵌入浏览器包，仅用于开发调试）──
# 本地 dev 模式下若不想在 defaultConfig.ts 写死 Key，可在此处配置
# VITE_DEEPSEEK_KEY=
# VITE_MINIMAX_TTS_KEY=
