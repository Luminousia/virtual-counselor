# 腾讯云 CloudBase 部署环境变量
# 复制为 .env.production.local 并填入真实值，或在 CloudBase 控制台「静态网站托管 → 构建环境变量」里配置
#
# 说明：配置了 VITE_CLOUDBASE_ENV_ID（或手写 VITE_AI_API_URL）后，前端生产包会将对 AI 的请求
# 发到 https://{env}.{region}.tcloudbaseapp.com/ai ，走 CloudBase cloudfunctions/ai（JSON，非 SSE）。
# TTS 走 .../tts 或同上 TTS_PROXY_URL。未配置时仍为同域 POST /api/ai（SSE，需自备 server/Vercel/CF）。

# CloudBase 环境 ID（必填）
# 登录 https://console.cloud.tencent.com/tcb → 选择环境 → 右上角"环境ID"
VITE_CLOUDBASE_ENV_ID=env-xxxxxx

# CloudBase 部署区域（默认上海）
# VITE_CLOUDBASE_REGION=ap-shanghai

# 如果不用 CLOUDBASE_ENV_ID 自动生成 URL，也可以手动填云函数的 HTTP 触发器地址
# VITE_AI_API_URL=https://env-xxxxxx.ap-shanghai.tcloudbaseapp.com/ai
# VITE_TTS_API_URL=https://env-xxxxxx.ap-shanghai.tcloudbaseapp.com/tts
