{
  "name": "virtual-human-counseling-game",
  "version": "2.0.0",
  "description": "虚拟数字人心理咨询师游戏 - 与温和、耐心、热情的小暖进行对话",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "start": "node server.cjs",
    "dev": "vite",
    "build": "node -e \"['dist','node_modules/.vite'].forEach(d=>{try{require('fs').rmSync(d,{recursive:true,force:true})}catch(e){}})\" && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "deploy:tcb": "npm run build && tcb hosting deploy ./dist / && tcb fn deploy ai --dir cloudfunctions/ai --path /ai --force && tcb fn deploy tts --dir cloudfunctions/tts --path /tts --force",
    "deploy:tcb:framework": "tcb framework deploy",
    "login:tcb": "tcb login"
  },
  "dependencies": {
    "@cloudbase/js-sdk": "^2.28.3",
    "@pixiv/three-vrm": "^3.4.4",
    "@pixiv/three-vrm-animation": "^3.5.2",
    "axios": "^1.6.2",
    "express": "^5.2.1",
    "framer-motion": "^10.16.16",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.182.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.2.2",
    "vite": "^6.4.2"
  }
}
